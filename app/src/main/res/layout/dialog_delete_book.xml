<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="#FDE7E7"
        android:padding="12dp"
        android:text="Are you sure? You will lose all entries of this book permanently"
        android:textColor="#B00020" />

    <TextView
        android:id="@+id/tvDeleteConfirmMsg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Please type BOOK_NAME to confirm" />

    <EditText
        android:id="@+id/etDeleteBookName"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Book Name"
        android:inputType="text" />
</LinearLayout>