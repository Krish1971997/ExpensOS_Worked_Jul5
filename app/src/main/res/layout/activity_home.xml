<?xml version="1.0" encoding="utf-8"?><!-- activity_home.xml — Full layout with DrawerLayout + BottomNav -->
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ── Main content ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg">

        <!-- Top toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/nav_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:elevation="4dp">

            <!-- Hamburger menu button -->
            <ImageButton
                android:id="@+id/btnHamburger"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:contentDescription="Menu"
                android:tint="@color/primary"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tvBookTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:ellipsize="end"
                android:maxLines="1" />

            <!-- Sync button -->
            <Button
                android:id="@+id/btnSync"
                style="@style/BtnPrimary"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="⟳ Sync"
                android:textSize="12sp"
                android:paddingHorizontal="14dp" />
        </LinearLayout>

        <!-- Fragment container — each bottom tab loads here -->
        <FrameLayout
            android:id="@+id/fragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- ── Bottom Navigation Bar ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@color/nav_bg"
            android:orientation="horizontal"
            android:elevation="8dp">

            <!-- Home -->
            <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/navHomeIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏠"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/navHomeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Home"
                    android:textSize="10sp"
                    android:textColor="@color/primary"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Reports -->
            <LinearLayout
                android:id="@+id/navReports"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/navReportsIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/navReportsLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reports"
                    android:textSize="10sp"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

            <!-- Backup -->
            <LinearLayout
                android:id="@+id/navBackup"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/navBackupIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🗄️"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/navBackupLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Backup"
                    android:textSize="10sp"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

            <!-- Configuration -->
            <LinearLayout
                android:id="@+id/navConfig"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/navConfigIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚙️"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/navConfigLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Config"
                    android:textSize="10sp"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

    <!-- ── Side Drawer (left) ── -->
    <LinearLayout
        android:id="@+id/sideDrawer"
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/bg_card"
        android:orientation="vertical">

        <!-- Drawer header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@color/primary"
            android:orientation="vertical"
            android:gravity="bottom"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📈 ExpenseOS"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/drawerBookName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#CCFFFFFF"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Drawer menu items -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp">

                <!-- Books -->
                <LinearLayout
                    android:id="@+id/drawerBooks"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="18dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="wrap_content"
                        android:text="📒"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cash Books"
                        android:textSize="14sp"
                        android:textColor="@color/text"
                        android:layout_marginStart="12dp" />
                </LinearLayout>

                <!-- Settings -->
                <LinearLayout
                    android:id="@+id/drawerSettings"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="18dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="wrap_content"
                        android:text="⚙"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Settings"
                        android:textSize="14sp"
                        android:textColor="@color/text"
                        android:layout_marginStart="12dp" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border"
                    android:layout_marginVertical="6dp" />

                <!-- Audit Log -->
                <LinearLayout
                    android:id="@+id/drawerAudit"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="18dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="wrap_content"
                        android:text="📋"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Audit Log"
                        android:textSize="14sp"
                        android:textColor="@color/text"
                        android:layout_marginStart="12dp" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- Drawer footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ExpenseOS v1.0"
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:gravity="center"
            android:padding="12dp" />
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>