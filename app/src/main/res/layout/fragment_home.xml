<?xml version="1.0" encoding="utf-8"?>
<!-- OPTION A — Cash In / Cash Out bar lives inside the fragment itself,
     as the last item in the vertical layout. Since the fragment already
     fills the space above the bottom nav bar, this bar naturally sits
     right above it — same visual result as the old app screenshot.
     No changes needed in HomeFragment.java: btn_add_income / btn_add_expense
     IDs are reused, just restyled + relabeled. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- Summary Cards -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center">

        <androidx.cardview.widget.CardView android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="3dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOTAL INCOME"
                    android:textSize="10sp"
                    android:textColor="#666" />

                <TextView
                    android:id="@+id/tv_total_income"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0.00"
                    android:textColor="#1B8A1B"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="3dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOTAL EXPENSES"
                    android:textSize="10sp"
                    android:textColor="#666" />

                <TextView
                    android:id="@+id/tv_total_expense"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0.00"
                    android:textColor="#C0392B"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="3dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NET BALANCE"
                    android:textSize="10sp"
                    android:textColor="#666" />

                <TextView
                    android:id="@+id/tv_net_balance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0.00"
                    android:textColor="#1565C0"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- Search + Filter row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/etTxnSearch"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:background="@android:color/white"
            android:hint="Search by remark or amount"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:singleLine="true"
            android:textSize="13sp" />

        <ImageButton
            android:id="@+id/btnTxnFilter"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="8dp"
            android:background="@android:color/white"
            android:contentDescription="Filter"
            android:padding="9dp"
            android:src="@drawable/ic_filter" />
    </LinearLayout>

    <!-- Scrollable filter pill row (Date / Category / Sub Category / Amount) —
         each pill opens the same TransactionFilterDialog jumped straight to
         that tab. Pill label updates to reflect the active selection
         (e.g. "Date: This Month") via HomeFragment.refreshFilterChips(). -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/chipDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_filter_chip"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="Date ▾"
                android:textColor="@color/text"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_filter_chip"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="Category ▾"
                android:textColor="@color/text"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipSubCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_filter_chip"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="Sub Category ▾"
                android:textColor="@color/text"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_filter_chip"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="Amount ▾"
                android:textColor="@color/text"
                android:textSize="13sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Top "+ Income" / "+ Expense" buttons REMOVED — replaced by the
         fixed Cash In / Cash Out bar at the bottom of this screen. -->

    <!-- Sync buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingBottom="10dp">

        <Button
            android:id="@+id/btn_sync_cloud"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="↑ Sync to Cloud"
            android:backgroundTint="#1565C0"
            android:textColor="@android:color/white"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_fetch_cloud"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="↓ Fetch from Cloud"
            android:backgroundTint="#6A1B9A"
            android:textColor="@android:color/white"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Transaction list -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_transactions"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingHorizontal="8dp"
            android:paddingBottom="8dp" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- ── Fixed Cash In / Cash Out bar (old-app style) ──────────────── -->
    <!-- IDs kept the SAME as before (btn_add_income / btn_add_expense) so
         HomeFragment.java's existing click listeners keep working untouched. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:background="@android:color/white"
        android:elevation="8dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp">

        <Button
            android:id="@+id/btn_add_income"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="+ CASH IN"
            android:backgroundTint="#1B8A1B"
            android:textColor="@android:color/white"
            android:textSize="17sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_add_expense"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="− CASH OUT"
            android:backgroundTint="#C0392B"
            android:textColor="@android:color/white"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>