<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical">

    <!-- Navbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/nav_bg"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <Button
            android:id="@+id/btnBulkBack"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="← Back"
            android:textSize="12sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="≡ Bulk Add Transactions"
            android:textColor="@color/text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnBulkSaveAll"
            style="@style/BtnSuccess"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:paddingHorizontal="12dp"
            android:text="✓ Save All"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Info bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#EFF6FF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:paddingVertical="8dp">

        <TextView
            android:id="@+id/tvBulkSummary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 rows"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnBulkAddRow"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginEnd="4dp"
            android:text="+ Row"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btnBulkAdd5"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginEnd="4dp"
            android:text="+ 5"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btnBulkClear"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="✕ Clear"
            android:textColor="@color/red"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Column headers -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:background="#F8FAFC"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp">

        <TextView
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:text="TYPE"
            android:textAllCaps="true"
            android:textColor="@color/text_muted"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:text="DATE &amp; TIME"
            android:textAllCaps="true"
            android:textColor="@color/text_muted"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.8"
            android:text="AMOUNT (₹)"
            android:textAllCaps="true"
            android:textColor="@color/text_muted"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CATEGORY"
            android:textAllCaps="true"
            android:textColor="@color/text_muted"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="NOTE"
            android:textAllCaps="true"
            android:textColor="@color/text_muted"
            android:textSize="9sp"
            android:textStyle="bold" />

        <View
            android:layout_width="32dp"
            android:layout_height="1dp" />
    </LinearLayout>

    <!-- Scrollable rows -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/llBulkRows"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="4dp" />
    </ScrollView>

    <!-- Bottom result + save -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/nav_bg"
        android:elevation="4dp"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:id="@+id/tvBulkResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnBulkSaveAllBottom"
            style="@style/BtnSuccess"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="✓ Save All Transactions" />
    </LinearLayout>
</LinearLayout>