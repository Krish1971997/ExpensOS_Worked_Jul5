<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Page title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙ Configuration"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All settings — mirrors web.xml parameters"
            android:textSize="12sp"
            android:textColor="@color/text_muted"
            android:layout_marginBottom="14dp" />

        <!-- ── DB CONFIG ── -->
        <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DATABASE CONFIG"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DB_URL"
                    android:textSize="10sp"
                    android:textColor="@color/text_muted"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etCfgDbUrl"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:inputType="text"
                    android:hint="jdbc:postgresql://host/dbname?sslmode=require"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DB_USER"
                    android:textSize="10sp"
                    android:textColor="@color/text_muted"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etCfgDbUser"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="postgres"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DB_PASSWORD"
                    android:textSize="10sp"
                    android:textColor="@color/text_muted"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etCfgDbPass"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:inputType="textPassword"
                    android:hint="••••••••"
                    android:layout_marginBottom="12dp" />

                <!-- Test Connection -->
                <Button
                    android:id="@+id/btnTestConnection"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="🔗 Test Connection"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvConnectionResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:padding="8dp"
                    android:background="#F8FAFC"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btnSaveCfgDb"
                    style="@style/BtnPrimary"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Save DB Config" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── GMAIL CONFIG ── -->
        <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GMAIL CONFIG"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/green"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GMAIL_FROM"
                    android:textSize="10sp"
                    android:textColor="@color/text_muted"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etCfgGmailFrom"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:inputType="textEmailAddress"
                    android:hint="yourname@gmail.com"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GMAIL_APP_PASS"
                    android:textSize="10sp"
                    android:textColor="@color/text_muted"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etCfgGmailPass"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:inputType="textPassword"
                    android:hint="xxxx xxxx xxxx xxxx"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnSaveCfgGmail"
                    style="@style/BtnPrimary"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Save Gmail Config" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── APP CONFIG ── -->
        <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="APP CONFIG"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/amber"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="backup.schedule.hour"
                            android:textSize="10sp"
                            android:textColor="@color/text_muted"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/etCfgBackupHour"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:inputType="number"
                            android:hint="0" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="backup.schedule.minute"
                            android:textSize="10sp"
                            android:textColor="@color/text_muted"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/etCfgBackupMinute"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:inputType="number"
                            android:hint="0" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="session-timeout (minutes)"
                    android:textSize="10sp"
                    android:textColor="@color/text_muted"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etCfgSessionTimeout"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:inputType="number"
                    android:hint="60"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="App Display Name"
                    android:textSize="10sp"
                    android:textColor="@color/text_muted"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etCfgAppName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="ExpenseOS"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Auto Sync on Launch"
                        android:textSize="13sp"
                        android:textColor="@color/text" />

                    <Switch
                        android:id="@+id/swAutoSync"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnSaveCfgApp"
                    style="@style/BtnPrimary"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Save App Config" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── SYNC CONFIG TO DB ── -->
        <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#EFF6FF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💾 Save All &amp; Sync to Cloud"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Saves all config locally AND pushes to app_config table in Neon DB. Passwords are NOT synced for security."
                    android:textSize="11sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btnSyncConfigToDb"
                    style="@style/BtnPrimary"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="☁ Save All + Sync Config to DB" />

                <TextView
                    android:id="@+id/tvSyncConfigStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:padding="8dp"
                    android:background="#FFFFFF"
                    android:visibility="gone"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>