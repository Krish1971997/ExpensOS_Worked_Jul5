<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical">

    <!-- Navbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/nav_bg"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <Button
            android:id="@+id/btnBackSettings"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="← Back"
            android:textSize="12sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⚙ Settings"
            android:textColor="@color/text"
            android:textSize="17sp"
            android:textStyle="bold" />

        <View
            android:layout_width="56dp"
            android:layout_height="1dp" />
    </LinearLayout>

    <!-- Mode banner: shows whether this is Global (common-only) or
         Cashbook-scoped settings. Text/visibility set in SettingsActivity. -->
    <TextView
        android:id="@+id/tvSettingsMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#EFF6FF"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:text="🌐 Global Settings — common categories only"
        android:textColor="@color/primary"
        android:textSize="11sp" />

    <!-- Tab buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@color/nav_bg"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp">

        <Button
            android:id="@+id/btnTabCat"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Categories"
            android:textColor="@color/primary"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnTabSub"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Sub-Cat"
            android:textColor="@color/text_muted"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnTabColumns"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Columns"
            android:textColor="@color/text_muted"
            android:textSize="12sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- ══ CATEGORIES PANEL ══ -->
            <LinearLayout
                android:id="@+id/panelCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Income / Expense sub-tabs -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tabCatIncome"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:paddingVertical="10dp"
                        android:text="Income"
                        android:textColor="@color/green"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tabCatExpense"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:paddingVertical="10dp"
                        android:text="Expense"
                        android:textColor="@color/text_muted"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Search + Add -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etCatSearch"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:hint="Search income category"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btnCatAdd"
                        style="@style/BtnSuccess"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:paddingHorizontal="16dp"
                        android:text="+ ADD"
                        android:textSize="12sp" />
                </LinearLayout>

                <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="2dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvCategoryList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:padding="6dp" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ══ SUB-CATEGORIES PANEL ══ -->
            <LinearLayout
                android:id="@+id/panelSubCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Income / Expense sub-tabs -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tabSubIncome"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:paddingVertical="10dp"
                        android:text="Income"
                        android:textColor="@color/green"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tabSubExpense"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:paddingVertical="10dp"
                        android:text="Expense"
                        android:textColor="@color/text_muted"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Search + Add -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etSubCatSearch"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:hint="Search sub category"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btnSubCatAdd"
                        style="@style/BtnPrimary"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:paddingHorizontal="16dp"
                        android:text="+ ADD"
                        android:textSize="12sp" />
                </LinearLayout>

                <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="2dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvSubCategoryList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:padding="6dp" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ══ CUSTOM COLUMNS PANEL (global-only — see note in SettingsActivity) ══ -->
            <LinearLayout
                android:id="@+id/panelColumns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="#FEF9C3"
                    android:padding="8dp"
                    android:text="ℹ Custom columns are shared across all cashbooks (no per-book scoping yet)."
                    android:textColor="@color/amber"
                    android:textSize="11sp" />

                <!-- Income Columns -->
                <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:letterSpacing="0.08"
                            android:text="INCOME CUSTOM COLUMNS"
                            android:textAllCaps="true"
                            android:textColor="@color/green"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <EditText
                                android:id="@+id/etNewIncomeCol"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_marginEnd="6dp"
                                android:layout_weight="1"
                                android:hint="New column, e.g. Payment Mode"
                                android:textSize="13sp" />

                            <Button
                                android:id="@+id/btnAddIncomeCol"
                                style="@style/BtnSuccess"
                                android:layout_width="wrap_content"
                                android:layout_height="44dp"
                                android:paddingHorizontal="10dp"
                                android:text="+ Add"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvIncomeColumns"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Expense Columns -->
                <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:letterSpacing="0.08"
                            android:text="EXPENSE CUSTOM COLUMNS"
                            android:textAllCaps="true"
                            android:textColor="@color/red"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <EditText
                                android:id="@+id/etNewExpenseCol"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_marginEnd="6dp"
                                android:layout_weight="1"
                                android:hint="New column, e.g. Payment Mode"
                                android:textSize="13sp" />

                            <Button
                                android:id="@+id/btnAddExpenseCol"
                                style="@style/BtnDanger"
                                android:layout_width="wrap_content"
                                android:layout_height="44dp"
                                android:paddingHorizontal="10dp"
                                android:text="+ Add"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvExpenseColumns"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>