<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/nav_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:elevation="4dp">

        <Button
            android:id="@+id/btnBackSettings"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="← Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚙ Settings"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/text"
            android:gravity="center" />

        <View
            android:layout_width="56dp"
            android:layout_height="36dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- DB Config Card -->
            <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DATABASE CONFIG (Neon PostgreSQL)"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_muted"
                        android:textAllCaps="true"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DB URL"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etDbUrl"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:inputType="text"
                        android:hint="jdbc:postgresql://host/dbname?sslmode=require"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="USERNAME"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etDbUser"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="postgres"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PASSWORD"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etDbPass"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:inputType="textPassword"
                        android:hint="••••••••"
                        android:layout_marginBottom="12dp" />

                    <Button
                        android:id="@+id/btnSaveDb"
                        style="@style/BtnPrimary"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="Save DB Config" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Gmail Config Card -->
            <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GMAIL CONFIG (for email reports)"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_muted"
                        android:textAllCaps="true"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FROM EMAIL"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etGmailFrom"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:inputType="textEmailAddress"
                        android:hint="yourname@gmail.com"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="APP PASSWORD"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etGmailPass"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:inputType="textPassword"
                        android:hint="xxxx xxxx xxxx xxxx"
                        android:layout_marginBottom="12dp" />

                    <Button
                        android:id="@+id/btnSaveGmail"
                        style="@style/BtnPrimary"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="Save Gmail Config" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Categories Card -->
            <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CATEGORIES"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_muted"
                        android:textAllCaps="true"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <EditText
                            android:id="@+id/etNewIncomeCat"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:hint="New income category"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btnAddIncomeCat"
                            style="@style/BtnSuccess"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="+ Add"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/etNewExpenseCat"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:hint="New expense category"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btnAddExpenseCat"
                            style="@style/BtnDanger"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="+ Add"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>