<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical">

    <!-- Navbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/nav_bg"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <Button
            android:id="@+id/btnBackSettings"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="← Back"
            android:textSize="12sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⚙ Settings"
            android:textColor="@color/text"
            android:textSize="17sp"
            android:textStyle="bold" />

        <View
            android:layout_width="56dp"
            android:layout_height="1dp" />
    </LinearLayout>

    <!-- Tab buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@color/nav_bg"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp">

        <Button
            android:id="@+id/btnTabCat"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Categories"
            android:textColor="@color/primary"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnTabSub"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Sub-Cat"
            android:textColor="@color/text_muted"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnTabGmail"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Gmail"
            android:textColor="@color/text_muted"
            android:textSize="12sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- ══ CATEGORIES PANEL ══ -->
            <LinearLayout
                android:id="@+id/panelCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Income Categories -->
                <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:letterSpacing="0.08"
                            android:text="INCOME CATEGORIES"
                            android:textAllCaps="true"
                            android:textColor="@color/green"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <!-- Add row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <EditText
                                android:id="@+id/etNewIncomeCat"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_marginEnd="6dp"
                                android:layout_weight="1"
                                android:hint="New income category"
                                android:textSize="13sp" />

                            <Spinner
                                android:id="@+id/spIncomeCatScope"
                                android:layout_width="wrap_content"
                                android:layout_height="44dp"
                                android:layout_marginEnd="6dp" />

                            <Button
                                android:id="@+id/btnAddIncomeCat"
                                style="@style/BtnSuccess"
                                android:layout_width="wrap_content"
                                android:layout_height="44dp"
                                android:paddingHorizontal="10dp"
                                android:text="+ Add"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvIncomeCategories"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Expense Categories -->
                <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:letterSpacing="0.08"
                            android:text="EXPENSE CATEGORIES"
                            android:textAllCaps="true"
                            android:textColor="@color/red"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <EditText
                                android:id="@+id/etNewExpenseCat"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_marginEnd="6dp"
                                android:layout_weight="1"
                                android:hint="New expense category"
                                android:textSize="13sp" />

                            <Spinner
                                android:id="@+id/spExpenseCatScope"
                                android:layout_width="wrap_content"
                                android:layout_height="44dp"
                                android:layout_marginEnd="6dp" />

                            <Button
                                android:id="@+id/btnAddExpenseCat"
                                style="@style/BtnDanger"
                                android:layout_width="wrap_content"
                                android:layout_height="44dp"
                                android:paddingHorizontal="10dp"
                                android:text="+ Add"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvExpenseCategories"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ══ SUB-CATEGORIES PANEL ══ -->
            <LinearLayout
                android:id="@+id/panelSubCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:letterSpacing="0.08"
                            android:text="SUB CATEGORIES"
                            android:textAllCaps="true"
                            android:textColor="@color/amber"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <!-- Add sub-cat -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Parent Category"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <Spinner
                            android:id="@+id/spSubCatParent"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sub-Category Name"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <EditText
                                android:id="@+id/etNewSubCatName"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_marginEnd="8dp"
                                android:layout_weight="1"
                                android:hint="e.g. Dinner, Netflix"
                                android:textSize="13sp" />

                            <Button
                                android:id="@+id/btnAddSubCat"
                                style="@style/BtnPrimary"
                                android:layout_width="wrap_content"
                                android:layout_height="44dp"
                                android:paddingHorizontal="12dp"
                                android:text="+ Add"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvSubCategories"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ══ GMAIL PANEL ══ -->
            <LinearLayout
                android:id="@+id/panelGmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:letterSpacing="0.08"
                            android:text="GMAIL CONFIG"
                            android:textAllCaps="true"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FROM EMAIL"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/etGmailFrom"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginBottom="10dp"
                            android:hint="yourname@gmail.com"
                            android:inputType="textEmailAddress" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="APP PASSWORD"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/etGmailPass"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginBottom="12dp"
                            android:hint="xxxx xxxx xxxx xxxx"
                            android:inputType="textPassword" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:background="#FEF9C3"
                            android:padding="8dp"
                            android:text="⚠ Use Gmail App Password (not your regular password).\nGoogle Account → Security → 2FA → App Passwords"
                            android:textColor="@color/amber"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnSaveGmail"
                            style="@style/BtnPrimary"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="Save Gmail Config" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>