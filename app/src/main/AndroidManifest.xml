<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Only needed for the legacy pre-scoped-storage Downloads save path
     (API 26-28) in DownloadsSaver — maxSdkVersion so it's a no-op
     (and doesn't show in the Play Store permission list) on API 29+,
     where MediaStore.Downloads is used instead. -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.ExpenseOS"
        android:usesCleartextTraffic="true">

        <receiver
            android:name="com.expenseos.sync.BackupScheduler$AutoBackupReceiver"
            android:exported="false" />

        <!-- Launch: Book Selector -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Main shell: Bottom Nav + Side Drawer -->
        <activity android:name=".ui.HomeActivity" />

        <!-- Feature screens -->
        <activity android:name=".ui.TransactionActivity" />
        <activity android:name=".ui.TransactionEntryActivity" />
        <activity android:name=".ui.GenerateReportActivity" />
        <activity android:name=".ui.TransactionDetailActivity" />
        <activity android:name=".ui.BulkAddActivity" />
        <activity android:name=".ui.SettingsActivity" />
        <activity android:name=".ui.AuditLogActivity" />
        <activity android:name=".ui.EntryDetailActivity" />
        <activity android:name=".ui.TxnEditHistoryActivity" />
        <activity android:name=".ui.AttachmentPreviewActivity" />
        <activity android:name=".ui.SchedulerActivity" />

        <!-- Needed for camera capture in TransactionEntryActivity — the
             camera app writes the photo to a content:// URI we hand it,
             which requires a FileProvider rather than a raw file:// path. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>